---
import { SITE_TITLE, SITE_DESCRIPTION } from "../consts.mjs";

interface Props {
  title?: string;
  description?: string;
}

const { title, description = SITE_DESCRIPTION } = Astro.props;
const pageTitle = title ? `${title}｜${SITE_TITLE}` : SITE_TITLE;
const base = import.meta.env.BASE_URL;
---

<!doctype html>
<html lang="ja">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{pageTitle}</title>
    <meta name="description" content={description} />
    <script
      is:inline
      async
      src="https://pagead2.googlesyndication.com/pagead/js/adsbygoogle.js?client=ca-pub-5741786934832383"
      crossorigin="anonymous"></script>
  </head>
  <body>
    <header>
      <a class="site-title" href={base}>{SITE_TITLE}</a>
      <p class="tagline">毎営業日、朝夕2回更新の市況まとめ</p>
    </header>
    <main>
      <slot />
    </main>
    <footer>
      <p>
        <a href={`${base}disclaimer/`}>免責事項</a>
      </p>
      <p>© {new Date().getFullYear()} {SITE_TITLE}</p>
    </footer>
  </body>
</html>

<style is:global>
  :root {
    --text: #1a2233;
    --muted: #5b6577;
    --accent: #0f5aa8;
    --bg: #f7f8fa;
    --card: #ffffff;
    --border: #dde3ea;
  }
  * { box-sizing: border-box; }
  body {
    margin: 0;
    font-family: "Hiragino Sans", "Yu Gothic", "Meiryo", sans-serif;
    color: var(--text);
    background: var(--bg);
    line-height: 1.8;
  }
  header {
    background: var(--card);
    border-bottom: 1px solid var(--border);
    padding: 1.2rem 1rem;
    text-align: center;
  }
  .site-title {
    font-size: 1.5rem;
    font-weight: 700;
    color: var(--text);
    text-decoration: none;
  }
  .tagline { margin: 0.3rem 0 0; font-size: 0.85rem; color: var(--muted); }
  main { max-width: 760px; margin: 0 auto; padding: 1.5rem 1rem 3rem; }
  footer {
    border-top: 1px solid var(--border);
    padding: 1.5rem 1rem;
    text-align: center;
    font-size: 0.85rem;
    color: var(--muted);
  }
  footer a { color: var(--accent); }
  h1 { font-size: 1.45rem; line-height: 1.5; }
  h2 {
    font-size: 1.15rem;
    border-left: 4px solid var(--accent);
    padding-left: 0.6rem;
    margin-top: 2rem;
  }
  table {
    border-collapse: collapse;
    width: 100%;
    margin: 1rem 0;
    background: var(--card);
    font-size: 0.92rem;
  }
  th, td { border: 1px solid var(--border); padding: 0.45rem 0.6rem; text-align: left; }
  th { background: #eef2f7; }
  a { color: var(--accent); }
</style>
